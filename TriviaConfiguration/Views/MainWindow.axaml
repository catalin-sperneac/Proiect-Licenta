<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TriviaConfiguration.Views.MainWindow"
        Width="950" Height="550"
        Title="Trivia Configuration">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Grid.Column="1"
                   Text="Trivia Configuration"
                   FontSize="30"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,30"/>

        <!-- Type -->
        <TextBlock Grid.Row="1" Grid.Column="1"
                   x:Name="TypeTextBlock"
                   Text="Type: "
                   FontSize="20"
                   Margin="0,0,0,20"
                   HorizontalAlignment="Center"/>

        <!-- Question -->
        <TextBlock Grid.Row="2" Grid.Column="1"
                   x:Name="QuestionTextBlock"
                   Text="Question goes here"
                   FontSize="24"
                   TextWrapping="Wrap"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   Margin="20,0,20,20"/>

        <!-- Correct Answer -->
        <TextBlock Grid.Row="3" Grid.Column="1"
                   x:Name="CorrectAnswerTextBlock"
                   Text="Correct Answer: "
                   FontSize="20"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- AI Button -->
        <Button Grid.Row="5" Grid.Column="0"
                x:Name="AIButton"
                Content="AI"
                Width="80" Height="40"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Background="#4CA3FF"
                Foreground="Black"
                Click="AIButton_Click"/>

        <!-- Delete Button -->
        <Button Grid.Row="5" Grid.Column="1"
                x:Name="DeleteButton"
                Content="Delete"
                Width="90" Height="40"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Background="#FF4C4C"
                Foreground="Black"
                Click="DeleteButton_Click"/>

        <!-- Modify Button -->       
        <Button Grid.Row="5" Grid.Column="1"
                x:Name="ModifyButton"
                Content="Modify"
                Width="90" Height="40"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Background="#FFE14C"
                Foreground="Black"
                Click="ModifyQuestion_Click"/>

        <!-- Bottom Right Controls -->
        <StackPanel Grid.Row="5" Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Spacing="10">

            <Button x:Name="AddQuestionButton"
                    Content="+"
                    Width="50" Height="40"
                    Background="#0fdf19"
                    Foreground="Black"
                    Click="AddQuestionButton_Click"/>

            <Button x:Name="PrevButton"
                    Content="←"
                    Width="50" Height="40"
                    Background="White"
                    Foreground="Black"
                    Click="PrevButton_Click"/>

            <TextBlock x:Name="QuestionNumberTextBlock"
                       Text="1 / 1"
                       VerticalAlignment="Center"
                       FontSize="18"/>

            <Button x:Name="NextButton"
                    Content="→"
                    Width="50" Height="40"
                    Background="White"
                    Foreground="Black"
                    Click="NextButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
