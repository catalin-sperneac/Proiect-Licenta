  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Items:\nHealth Potion - fully restores HP\nIntelligence Potion - eliminates
    2 answers or gives an hint for a single turn\nDamage Potion - doubles damage
    for a single turn\nKey - Unlocks next level\nItems can be used only during a
    battle\n\nUpgrades:\nHealth Upgrade - Permanently increases HP by 1 point \nDamage
    Upgrade - Permanently increases damage by 1 point\n\nDifficulty:\nMedium - enemy
    damage = 1, spawn chance = 10% every second\nHard - enemy damage = 2, spawn chance
    = 20% every second\n\nGame Modes:\nStory (Normal or Hard) - Start a new journey,
    infinite amount of lifes\nEndless - Every level is procedurally generated, only
    1 life"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
